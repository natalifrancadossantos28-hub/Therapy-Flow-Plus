# ─── Desenvolvimento local (Replit define automaticamente) ───────────────────
PORT=3000
BASE_PATH=/triagem/

# ─── Variáveis de build (opcionais no Vercel) ────────────────────────────────
# Deixe em branco para Vercel — o vite.config.ts usa "/" como padrão

# ─── API Backend ──────────────────────────────────────────────────────────────
# URL do servidor de API (sem barra final).
# Em produção na Vercel, aponte para onde o api-server está hospedado.
# Exemplo: https://seu-api.railway.app
VITE_API_URL=

# ─── Configurações Vercel ─────────────────────────────────────────────────────
# No painel do Vercel, configure:
#   Root Directory:    artifacts/triagem
#   Build Command:     cd ../.. && pnpm install && pnpm --filter @workspace/triagem build
#   Output Directory:  dist
#   Install Command:   cd ../.. && pnpm install
