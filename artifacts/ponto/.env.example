# ─── Desenvolvimento local (Replit define automaticamente) ───────────────────
PORT=3000
BASE_PATH=/

# ─── Supabase (obrigatório — login roda 100% em Supabase desde a Fase 1) ─────
#
# No Supabase Dashboard → Settings → API:
#   VITE_SUPABASE_URL       = "Project URL"          (ex.: https://abcd.supabase.co)
#   VITE_SUPABASE_ANON_KEY  = chave "anon public"    (começa com eyJ...)
#
# Ambas são públicas (embutidas no bundle). A proteção dos dados é feita por
# RLS + funções SECURITY DEFINER. Veja supabase/migrations/*.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── (Legado) API Backend Express — ainda usado por endpoints não migrados ───
# Fase 1 migrou APENAS o login para Supabase. Endpoints de ponto/employees/
# records ainda passam pelo Express em VITE_API_URL. Pode deixar vazio se você
# não vai mais usar o backend Express; nesse caso, features ainda não
# migradas vão falhar com mensagem clara.
VITE_API_URL=

# ─── Configurações do Vercel ─────────────────────────────────────────────────
# No painel do Vercel, crie um PROJETO NOVO para este app e configure:
#   Root Directory:    artifacts/ponto
#   Framework Preset:  Other
#   Build Command:     (deixe o default — vem de artifacts/ponto/vercel.json)
#   Output Directory:  (deixe o default — vem de artifacts/ponto/vercel.json)
#   Install Command:   (deixe o default — vem de artifacts/ponto/vercel.json)
#
# Variáveis de ambiente a definir no Vercel (Settings → Environment Variables):
#   VITE_SUPABASE_URL      = URL do projeto Supabase
#   VITE_SUPABASE_ANON_KEY = chave anon public
#   VITE_API_URL           = (opcional) URL do backend Express legado
