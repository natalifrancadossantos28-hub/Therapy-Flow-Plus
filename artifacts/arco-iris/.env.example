# ─── Desenvolvimento local (Replit define automaticamente) ───────────────────
PORT=3000
BASE_PATH=/

# ─── API Backend (VITE_API_URL) ───────────────────────────────────────────────
#
# Em desenvolvimento (Replit):
#   Deixe VAZIO — o proxy do Vite encaminha /api → localhost:8080 automaticamente.
#
# Em produção (Vercel):
#   Aponte para o backend publicado no Replit.
#   Exemplo (substitua pelo URL real após publicar o projeto no Replit):
#
#   VITE_API_URL=https://workspace--natalifrancados.replit.app
#
# IMPORTANTE: sem barra no final e sem "/api" — o código acrescenta "/api" sozinho.
VITE_API_URL=

# ─── Configurações do Vercel ─────────────────────────────────────────────────
# No painel do Vercel, crie um PROJETO NOVO para este app e configure:
#   Root Directory:    artifacts/arco-iris
#   Framework Preset:  Other
#   Build Command:     (deixe o default — vem de artifacts/arco-iris/vercel.json)
#   Output Directory:  (deixe o default — vem de artifacts/arco-iris/vercel.json)
#   Install Command:   (deixe o default — vem de artifacts/arco-iris/vercel.json)
#
# Variável de ambiente a definir no Vercel:
#   VITE_API_URL = URL do backend Replit publicado (veja acima)
